# Server runtime
PORT=8787
DB_FILE=data/isles.db
WEB_ORIGIN=http://localhost:5173

# Set NODE_ENV=production to disable the dev-login bypass.
# In production you must configure GitHub OAuth below to sign in.
# NODE_ENV=production

# GitHub OAuth — register an app at https://github.com/settings/developers
# Required in production; without them the dev bypass signs you in as the seeded master.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# MCP server only (used by `pnpm --filter @frontier-isles/server mcp`)
# ISLAND=machine-curiosity
# AGENT=github:my-scout
